#!/usr/bin/env python3
"""Generate digest reports from Second Brain activity logs."""
import argparse, json, sys
from datetime import datetime, date, timedelta
from pathlib import Path

REPO = Path("/home/tokisaki/github/hermes-second-brain")
REPORTS = REPO / "reports"

def latest_report(prefix):
    files = sorted(REPORTS.glob(f"{prefix}_*.json"), reverse=True)
    return files[0] if files else None

def compile_digest():
    # Read latest compile log
    compile_log = latest_report("compile")
    lint_log = latest_report("lint")
    
    if not compile_log:
        return "# Daily Digest\n\nNo compile data available.\n"
    
    data = json.loads(compile_log.read_text())
    compiled = data.get("compiled", [])
    skipped = data.get("skipped", [])
    total = data.get("total_sources", 0)
    
    digest = f"""# Daily Digest — {date.today().isoformat()}

## Summary
- **Sources:** {total} total, {len(compiled)} new, {len(skipped)} unchanged
- **Wiki pages:** {len(list((REPO/'wiki').glob('*.md')))} total

## New Pages
"""
    if compiled:
        for page in compiled:
            digest += f"- {page}\n"
    else:
        digest += "_No new pages compiled._\n"
    
    # Include lint status
    if lint_log:
        lint_data = json.loads(lint_log.read_text())
        errors = lint_data.get("summary",{}).get("errors",0)
        warnings = lint_data.get("summary",{}).get("warnings",0)
        digest += f"\n## Health\n- **Errors:** {errors}\n- **Warnings:** {warnings}\n"
    
    digest += f"\n---\n*Generated: {datetime.now().isoformat()}*\n"
    return digest

def weekly_digest():
    # Aggregate past 7 days
    digest = f"""# Weekly Insights — Week of {date.today().isoformat()}

## Activity Overview
"""
    # Count compiles in last 7 days
    week_ago = date.today() - timedelta(days=7)
    compiles = [json.loads(p.read_text()) for p in REPORTS.glob("compile_*.json") 
                if datetime.strptime(p.stem.split('_')[1], '%Y%m%d').date() >= week_ago]
    
    total_new = sum(len(c.get("compiled",[])) for c in compiles)
    digest += f"- Pages compiled this week: {total_new}\n"
    
    # Graph stats
    nodes = json.loads((REPO / "memory/graph.nodes.json").read_text())
    edges = json.loads((REPO / "memory/graph.edges.json").read_text())
    digest += f"- Knowledge graph: {len(nodes)} nodes, {len(edges)} edges\n"
    
    digest += "\n---\n*Weekly digest generated.*\n"
    return digest

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--daily", action="store_true", help="Generate daily digest")
    parser.add_argument("--weekly", action="store_true", help="Generate weekly digest")
    parser.add_argument("-o", "--output", help="Write to file")
    args = parser.parse_args()
    
    if args.daily:
        out = compile_digest()
    elif args.weekly:
        out = weekly_digest()
    else:
        print("Use --daily or --weekly")
        sys.exit(1)
    
    if args.output:
        Path(args.output).write_text(out)
        print(f"Digest written to {args.output}")
    else:
        print(out)

if __name__ == "__main__":
    main()
